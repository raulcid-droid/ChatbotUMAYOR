<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_chat_umayor_config_form" model="ir.ui.view">
        <field name="name">chat.umayor.config.form</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Chat UMayor — Configuración">
                <sheet>
                    <group string="Gemini AI">
                        <field name="chat_umayor_gemini_api_key" password="True"/>
                        <field name="chat_umayor_gemini_model"/>
                        <field name="chat_umayor_gemini_timeout"/>
                    </group>
                    <group string="System Prompt">
                        <field name="chat_umayor_system_prompt" widget="text" nolabel="1"/>
                    </group>
                    <group string="Firma Electrónica">
                        <field name="chat_umayor_sign_template_id"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Guardar" name="execute" type="object" class="btn-primary"/>
                    <button string="Descartar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_chat_umayor_config" model="ir.actions.act_window">
        <field name="name">Chat UMayor</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_chat_umayor_config_form"/>
        <field name="target">current</field>
    </record>

    <menuitem id="menu_chat_umayor_config"
              name="Chat UMayor"
              action="action_chat_umayor_config"
              parent="base.menu_administration"
              sequence="100"/>
</odoo>
