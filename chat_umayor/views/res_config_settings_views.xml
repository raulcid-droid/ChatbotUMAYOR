<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_chat_umayor" model="ir.ui.view">
        <field name="name">res.config.settings.view.chat.umayor</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Chat UMayor" string="Chat UMayor" name="chat_umayor">
                    <block title="Gemini AI" id="chat_umayor_gemini_settings">
                        <setting string="API Key" help="Clave de API de Google Gemini.">
                            <field name="chat_umayor_gemini_api_key" password="True" placeholder="AIza..."/>
                        </setting>
                        <setting string="Modelo" help="Identificador del modelo Gemini.">
                            <field name="chat_umayor_gemini_model" placeholder="gemini-2.5-flash-lite"/>
                        </setting>
                        <setting string="Timeout (s)" help="Tiempo máximo de espera del LLM.">
                            <field name="chat_umayor_gemini_timeout"/>
                        </setting>
                        <setting string="Plantilla de firma" help="Plantilla de Odoo Sign para el flujo de firma.">
                            <field name="chat_umayor_sign_template_id"/>
                        </setting>
                    </block>
                    <block title="System Prompt" id="chat_umayor_prompt_settings">
                        <setting help="Prompt de sistema enviado a Gemini antes del historial.">
                            <field name="chat_umayor_system_prompt"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
