<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_chat_umayor" model="ir.ui.view">
        <field name="name">res.config.settings.view.chat.umayor</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="." position="inside">
                <div class="app_settings_block" data-string="Chat UMayor" string="Chat UMayor" data-key="chat_umayor">
                    <h2>Chat UMayor</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Asistente Virtual Banco UMayor</span>
                                <div class="text-muted">
                                    Configura la API Key de Gemini, modelo, timeout y system prompt.
                                </div>
                                <div class="content-group mt8">
                                    <button string="Abrir Configuración"
                                            name="action_open_chat_umayor_config"
                                            type="object"
                                            class="btn btn-primary"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
